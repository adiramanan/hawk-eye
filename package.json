{
  "name": "hawk-eye",
  "version": "0.0.1",
  "description": "Visual design tool for refining AI-generated React interfaces",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm -F @hawk-eye/client dev\" \"pnpm -F @hawk-eye/vite-plugin dev\" \"pnpm -F hawk-eye-demo dev\"",
    "build": "pnpm -r build",
    "build:client": "pnpm -F @hawk-eye/client build",
    "build:plugin": "pnpm -F @hawk-eye/vite-plugin build",
    "type-check": "pnpm -r type-check",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.1.0",
    "typescript": "^5.9.2",
    "tsup": "^8.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "concurrently": "^8.2.0"
  }
}

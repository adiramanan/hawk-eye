{
  "name": "@hawk-eye/vite-plugin",
  "version": "0.0.1",
  "description": "Vite plugin for source code mapping and code mutation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "ts-morph": "^21.0.0",
    "@babel/core": "^7.23.0",
    "@babel/plugin-syntax-jsx": "^7.23.0",
    "diff": "^5.1.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/diff": "^5.0.0",
    "typescript": "^5.9.2",
    "tsup": "^8.0.0",
    "vite": "^5.0.0"
  }
}

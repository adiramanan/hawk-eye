{
  "name": "hawk-eye",
  "version": "0.0.1",
  "description": "Visual design tool for refining AI-generated React interfaces in React + Vite development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm --dir ../.. type-check && pnpm --dir ../.. lint && pnpm --dir ../.. test && pnpm --dir ../.. build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "tsup": "^8.0.0"
  }
}

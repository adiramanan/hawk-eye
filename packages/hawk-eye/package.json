{
  "name": "hawk-eye",
  "version": "0.0.1",
  "description": "Visual design tool for refining AI-generated React interfaces in React + Vite development",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hawk-eye": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "vite",
    "design",
    "inspector"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adiramanan/hawk-eye.git"
  },
  "bugs": {
    "url": "https://github.com/adiramanan/hawk-eye/issues"
  },
  "homepage": "https://github.com/adiramanan/hawk-eye#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm --dir ../.. type-check && pnpm --dir ../.. lint && pnpm --dir ../.. test && pnpm --dir ../.. build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "ts-morph": "^21.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "tsup": "^8.0.0"
  }
}
